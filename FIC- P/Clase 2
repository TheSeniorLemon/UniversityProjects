* cat /etc/passwd

murcia:x:1000:983:example:/home/murcia:/usr/bin/bash
murcia= nombre  usuario
x= contraseña encriptada usuario
1000 = User ID
983 = Group ID
example = User Personal Info
/home/murcia = ruta personal del usuario
/usr/bin/bash = interprete habilitado al usuario

